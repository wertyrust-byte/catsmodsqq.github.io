# Функция для обхода platoboost
def bypass_platoboost(url):
    try:
        # Извлекаем ID из URL
        match = re.search(r'id=(\d+)', url)
        if not match:
            return None
        
        # Отправляем запрос к API
        api_url = f"https://gateway.platoboost.com/a/8?id={match.group(1)}"
        headers = {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
            "Referer": "https://platoboost.app/"
        }
        
        response = requests.get(api_url, headers=headers, allow_redirects=False)
        
        # Проверяем параметр r (base64)
        if 'r=' in response.headers.get('Location', ''):
            location = response.headers.get('Location', '')
            match_r = re.search(r'r=([^&]+)', location)
            if match_r:
                decoded = base64.b64decode(match_r.group(1)).decode('utf-8')
                return decoded
                
        return "https://loot-link.com/s?r=Y2xhc3M="
    except Exception as e:
        return f"Ошибка: {str(e)}"

