# Обработка ссылки
async def handle_link(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.user_data.get('awaiting_link', False):
        return
    
    link = update.message.text.strip()
    context.user_data['awaiting_link'] = False
    
    loading_msg = await update.message.reply_text(f"{EMOJIS['loading']} Обхожу ссылку...")
    
    # Обработка разных сервисов
    if 'platoboost.app' in link:
        result = bypass_platoboost(link)
    else:
        result = "❌ Этот сервис пока не поддерживается. Поддерживается: platoboost.app"
    
    keyboard = [[InlineKeyboardButton(f"{EMOJIS['bypass']} Обойти еще", callback_data='bypass_link')],
                [InlineKeyboardButton(f"{EMOJIS['back']} В меню", callback_data='back_to_menu')]]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    await loading_msg.delete()
    
    await update.message.reply_text(
        f"{EMOJIS['success']} <b>Готово!</b>\n\nОбойденная ссылка:\n<code>{result}</code>\n\n{EMOJIS['warning']} Скопируй ссылку и вставь в браузер",
        parse_mode='HTML',
        reply_markup=reply_markup
    )

